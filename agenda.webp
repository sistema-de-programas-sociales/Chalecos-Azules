.portal-commandbar {
  border-bottom-color: #d6e1ec;
  background: rgba(251, 253, 255, 0.97);
  box-shadow: 0 10px 32px rgba(6, 44, 86, 0.07);
}
.portal-commandbar::before {
  height: 4px;
  background: var(--color-brand-blue);
}
.portal-commandbar__inner {
  grid-template-columns: minmax(15rem, 1fr) auto minmax(15rem, 1fr);
  width: min(100% - 2.5rem, 96rem);
  min-height: 5.15rem;
  gap: 2rem;
}
.portal-brand {
  gap: 0.9rem;
}
.portal-brand__mark {
  position: relative;
  width: 3rem;
  height: 3rem;
  border-radius: 0.9rem;
  box-shadow: 0 11px 25px rgba(4, 77, 152, 0.22), inset 0 0 0 1px rgba(255,255,255,0.16);
}
.portal-brand__mark::after {
  content: "";
  position: absolute;
  right: -0.18rem;
  bottom: 0.38rem;
  width: 0.42rem;
  height: 0.9rem;
  border: 2px solid #fff;
  border-radius: 99px;
  background: #29a7d9;
}
.portal-brand__mark svg {
  width: 1.7rem;
  height: 1.7rem;
}
.portal-brand strong {
  font-size: 1.0625rem;
  letter-spacing: -0.025em;
}
.portal-brand small {
  margin-top: 0.12rem;
  font-size: var(--text-meta);
  letter-spacing: 0.045em;
}
.portal-desktop-nav {
  gap: 0.1rem;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}
.portal-desktop-nav > a, .portal-dropdown__trigger {
  position: relative;
  min-height: 3.25rem;
  border-radius: 0.65rem;
  padding-inline: 1rem;
  color: #52667a;
  font-weight: 720;
}
.portal-desktop-nav > a[data-active], .portal-dropdown__trigger[aria-expanded="true"], .portal-dropdown__trigger[data-section-active] {
  background: #eaf3fb;
  color: var(--color-brand-blue);
  box-shadow: inset 0 0 0 1px rgba(4,77,152,0.08);
}
.portal-desktop-nav > a[data-active]::after, .portal-dropdown__trigger[aria-expanded="true"]::after, .portal-dropdown__trigger[data-section-active]::after {
  content: "";
  position: absolute;
  right: 1rem;
  bottom: -0.95rem;
  left: 1rem;
  height: 3px;
  border-radius: 3px 3px 0 0;
  background: var(--color-brand-blue);
}
.portal-commandbar__actions {
  gap: 0.9rem;
}
.portal-live-status {
  grid-template-columns: 2.25rem auto;
  grid-template-rows: auto auto;
  column-gap: 0.7rem;
  min-width: 9.6rem;
  padding: 0.5rem 0.75rem 0.5rem 0.55rem;
  border-color: #cbdbe9;
  border-radius: 0.75rem;
  background: #f3f8fc;
  line-height: 1.15;
}
.portal-live-status > i {
  display: none;
}
.portal-live-status__icon {
  grid-row: 1 / 3;
  display: grid;
  width: 2.25rem;
  height: 2.25rem;
  place-items: center;
  border-radius: 0.58rem;
  background: #e3f0fa;
  color: var(--color-brand-blue);
}
.portal-live-status__icon svg {
  width: 1.18rem;
  height: 1.18rem;
}
.portal-live-status > span:not(.portal-live-status__icon) {
  align-self: end;
  color: #607085;
  font-size: var(--text-meta);
}
.portal-live-status strong {
  align-self: start;
  font-size: var(--text-meta);
  letter-spacing: 0.035em;
}
@media (hover: hover) and (pointer: fine) {
  .portal-desktop-nav > a:hover, .portal-dropdown__trigger:hover {
    background: #f0f5f9;
    color: var(--color-brand-blue);
  }
}
@media (max-width: 1023px) {
  .portal-commandbar__inner {
    grid-template-columns: 1fr auto;
    width: min(100% - 2rem, 96rem);
    min-height: 4.75rem;
    gap: 1rem;
  }
  .portal-desktop-nav {
    display: none;
  }
  .portal-live-status > span:not(.portal-live-status__icon) {
    display: none;
  }
  .portal-live-status {
    grid-template-columns: 2.25rem auto;
    min-width: 0;
  }
}
@media (max-width: 767px) {
  .portal-commandbar__inner {
    width: min(100% - 1.25rem, 96rem);
    min-height: 4.5rem;
  }
  .portal-brand__mark {
    width: 2.55rem;
    height: 2.55rem;
  }
  .portal-brand__mark svg {
    width: 1.45rem;
    height: 1.45rem;
  }
  .portal-brand strong {
    font-size: 1rem;
  }
  .portal-live-status {
    display: none;
  }
}
@layer polish {
  .portal-app {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    background: #eaf1f8;
  }
  .portal-commandbar {
    position: relative;
    z-index: 40;
    flex: none;
    border-bottom: 1px solid rgba(6, 44, 86, 0.13);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 12px 40px rgba(6, 44, 86, 0.08);
    backdrop-filter: blur(18px) saturate(140%);
  }
  .portal-commandbar::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, #044d98 0 58%, #29a7d9 58% 82%, #80c4e4 82%);
  }
  .portal-commandbar__inner {
    display: grid;
    grid-template-columns: minmax(13rem, 1fr) auto minmax(13rem, 1fr);
    align-items: center;
    width: min(100% - 2rem, 92rem);
    min-height: 4.75rem;
    margin-inline: auto;
    gap: 1.5rem;
  }
  .portal-brand {
    display: inline-flex;
    align-items: center;
    width: max-content;
    gap: 0.75rem;
    color: var(--color-portal-ink);
    text-decoration: none;
  }
  .portal-brand__mark {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border-radius: 0.75rem;
    background: var(--color-brand-blue);
    color: #fff;
    box-shadow: 0 9px 24px rgba(4, 77, 152, 0.24);
  }
  .portal-brand__mark svg {
    width: 1.55rem;
    height: 1.55rem;
  }
  .portal-brand strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 850;
    letter-spacing: -0.02em;
  }
  .portal-brand small {
    display: block;
    margin-top: 0.05rem;
    color: var(--color-portal-muted);
    font-family: var(--font-data);
    font-size: 0.58rem;
    letter-spacing: 0.04em;
  }
  .portal-desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.3rem;
    border: 1px solid rgba(6, 44, 86, 0.1);
    border-radius: 0.8rem;
    background: #f4f8fc;
  }
  .portal-desktop-nav > a, .portal-dropdown__trigger {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    border-radius: 0.55rem;
    padding-inline: 0.85rem;
    color: #536579;
    font-size: 0.78rem;
    font-weight: 750;
    white-space: nowrap;
    transition: color 160ms ease, background-color 160ms ease, transform 120ms var(--portal-ease);
  }
  .portal-desktop-nav > a[data-active], .portal-dropdown__trigger[aria-expanded="true"], .portal-dropdown__trigger[data-section-active] {
    background: #fff;
    color: var(--color-brand-blue);
    box-shadow: 0 4px 14px rgba(6, 44, 86, 0.1);
  }
  .portal-dropdown {
    position: relative;
  }
  .portal-dropdown__trigger {
    gap: 0.35rem;
    cursor: pointer;
  }
  .portal-dropdown__trigger svg {
    width: 0.95rem;
    height: 0.95rem;
    transition: transform 180ms var(--portal-ease);
  }
  .portal-dropdown__trigger[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
  .portal-dropdown__panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    width: 23rem;
    overflow: hidden;
    border: 1px solid #d4dee8;
    border-radius: 0.85rem;
    background: #fff;
    color: var(--color-portal-ink);
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    transform-origin: top right;
    box-shadow: 0 24px 64px rgba(6, 44, 86, 0.2), 0 4px 14px rgba(6, 44, 86, 0.08);
    transition: opacity 150ms var(--portal-ease), transform 180ms var(--portal-ease);
  }
  .portal-dropdown__panel.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .portal-dropdown__head {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    align-items: center;
    gap: 0.75rem;
    min-height: 4.5rem;
    border-bottom: 1px solid #e2e8ef;
    padding: 0.75rem 1rem;
    background: #f7fafc;
  }
  .portal-dropdown__head-icon {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border: 1px solid #c7d9ea;
    border-radius: 0.65rem;
    background: #fff;
    color: var(--color-brand-blue);
    box-shadow: 0 4px 12px rgba(6,44,86,0.06);
  }
  .portal-dropdown__head-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .portal-dropdown__head strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 800;
    line-height: 1.25;
  }
  .portal-dropdown__head small {
    display: block;
    margin-top: 0.18rem;
    color: #607085;
    font-size: var(--text-meta);
    line-height: 1.35;
  }
  .portal-dropdown__body {
    padding: 0.5rem;
  }
  .portal-dropdown__item {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr) 1rem;
    align-items: center;
    gap: 0.75rem;
    min-height: 4.25rem;
    border: 1px solid transparent;
    border-radius: 0.65rem;
    padding: 0.65rem 0.75rem;
    color: var(--color-portal-ink);
    text-decoration: none;
    transition: background-color 160ms ease, border-color 160ms ease, transform 140ms var(--portal-ease);
  }
  .portal-dropdown__item + .portal-dropdown__item {
    margin-top: 0.25rem;
  }
  .portal-dropdown__item[data-active], .portal-dropdown__item:hover, .portal-dropdown__item:focus-visible {
    border-color: #d5e3ef;
    background: #f0f6fb;
    outline: none;
  }
  .portal-dropdown__item[data-active] {
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .portal-dropdown__item strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 800;
    line-height: 1.25;
  }
  .portal-dropdown__item small {
    display: block;
    margin-top: 0.16rem;
    color: #607085;
    font-size: var(--text-meta);
    line-height: 1.35;
  }
  .portal-dropdown__icon {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border-radius: 0.6rem;
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .portal-dropdown__icon svg {
    width: 1.2rem;
    height: 1.2rem;
  }
  .portal-dropdown__arrow {
    width: 1rem;
    height: 1rem;
    color: #91a0b1;
    transition: color 150ms ease, transform 150ms var(--portal-ease);
  }
  .portal-dropdown__item:hover .portal-dropdown__arrow, .portal-dropdown__item:focus-visible .portal-dropdown__arrow, .portal-dropdown__item[data-active] .portal-dropdown__arrow {
    color: var(--color-brand-blue);
    transform: translateX(2px);
  }
  .portal-dropdown__foot {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-top: 1px solid #e2e8ef;
    padding: 0.65rem 1rem;
    background: #fbfcfd;
    color: #607085;
    font-size: var(--text-meta);
  }
  .portal-dropdown__foot i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #26966f;
    box-shadow: 0 0 0 3px rgba(38,150,111,0.12);
  }
  .portal-commandbar__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }
  .portal-live-status {
    display: inline-grid;
    grid-template-columns: auto auto;
    grid-template-rows: auto auto;
    column-gap: 0.45rem;
    align-items: center;
    padding: 0.42rem 0.65rem;
    border: 1px solid #c6d8e9;
    border-radius: 0.65rem;
    background: #edf5fc;
    color: var(--color-portal-muted);
    font-size: 0.59rem;
    line-height: 1;
  }
  .portal-live-status i {
    grid-row: 1 / 3;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #1f9d72;
    box-shadow: 0 0 0 4px rgba(31,157,114,0.12);
  }
  .portal-live-status strong {
    color: var(--color-brand-blue);
    font-family: var(--font-data);
    font-size: 0.65rem;
  }
  .portal-menu-button {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border-radius: 0.72rem;
    background: var(--color-brand-blue);
    box-shadow: 0 8px 20px rgba(4,77,152,0.2);
  }
  .portal-menu-button span {
    position: absolute;
    width: 1.1rem;
    height: 1.5px;
    border-radius: 99px;
    background: #fff;
    transition: transform 180ms var(--portal-ease), opacity 120ms ease;
  }
  .portal-menu-button span:nth-child(1) {
    transform: translateY(-5px);
  }
  .portal-menu-button span:nth-child(3) {
    transform: translateY(5px);
  }
  .portal-menu-button.is-open span:nth-child(1) {
    transform: rotate(45deg);
  }
  .portal-menu-button.is-open span:nth-child(2) {
    opacity: 0;
  }
  .portal-menu-button.is-open span:nth-child(3) {
    transform: rotate(-45deg);
  }
  .portal-stage {
    flex: 1;
    min-height: 0;
    background: #eaf1f8;
  }
  .portal-stage, .portal-frame {
    min-width: 0;
    max-width: 100%;
  }
  .portal-frame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .portal-mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 44;
    background: rgba(6,27,52,0.48);
    opacity: 0;
    backdrop-filter: blur(4px);
    transition: opacity 180ms ease;
  }
  .portal-mobile-overlay.is-open {
    opacity: 1;
  }
  .portal-mobile-menu {
    position: fixed;
    inset: 0 0 0 auto;
    z-index: 45;
    display: flex;
    width: min(92vw, 25rem);
    flex-direction: column;
    background: #082f59;
    color: #fff;
    transform: translateX(100%);
    box-shadow: -24px 0 70px rgba(6,27,52,0.34);
    transition: transform 260ms var(--portal-ease-drawer);
  }
  .portal-mobile-menu.is-open {
    transform: translateX(0);
  }
  .portal-mobile-menu__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 5.5rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .portal-mobile-menu__head small {
    display: block;
    color: #80c4e4;
    font-family: var(--font-data);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .portal-mobile-menu__head strong {
    display: block;
    margin-top: 0.2rem;
    font-size: 1.15rem;
  }
  .portal-mobile-menu__head button {
    display: grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border-radius: 0.65rem;
    background: rgba(255,255,255,0.1);
  }
  .portal-mobile-menu__head svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .portal-mobile-menu__nav {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
  }
  .portal-mobile-menu__nav a {
    display: grid;
    grid-template-columns: 2rem 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    border-radius: 0.75rem;
    padding: 0.85rem;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    opacity: 0;
    transform: translateX(12px);
    transition: color 160ms ease, background-color 160ms ease, opacity 240ms var(--portal-ease), transform 240ms var(--portal-ease);
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a {
    opacity: 1;
    transform: translateX(0);
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a:nth-child(1) {
    transition-delay: 25ms;
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a:nth-child(2) {
    transition-delay: 50ms;
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a:nth-child(3) {
    transition-delay: 75ms;
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a:nth-child(4) {
    transition-delay: 100ms;
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a:nth-child(5) {
    transition-delay: 125ms;
  }
  .portal-mobile-menu.is-open .portal-mobile-menu__nav a:nth-child(6) {
    transition-delay: 150ms;
  }
  .portal-mobile-menu__nav a + a {
    margin-top: 0.2rem;
  }
  .portal-mobile-menu__nav a > span {
    grid-row: 1 / 3;
    align-self: center;
    color: #80c4e4;
    font-family: var(--font-data);
    font-size: 0.65rem;
  }
  .portal-mobile-menu__nav a strong {
    color: #fff;
    font-size: 0.95rem;
  }
  .portal-mobile-menu__nav a small {
    margin-top: 0.12rem;
    color: rgba(255,255,255,0.52);
    font-size: 0.7rem;
  }
  .portal-mobile-menu__nav a[data-active] {
    background: rgba(255,255,255,0.1);
  }
  .portal-mobile-menu__foot {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem;
    padding: 1rem;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .portal-mobile-menu__foot span {
    border-radius: 0.65rem;
    background: rgba(255,255,255,0.08);
    padding: 0.75rem;
    color: rgba(255,255,255,0.58);
    font-size: 0.65rem;
  }
  .portal-mobile-menu__foot strong {
    display: block;
    color: #fff;
    font-family: var(--font-data);
    font-size: 1rem;
  }
  .portal-fragment {
    background: radial-gradient(circle at 85% 0%, rgba(41,167,217,0.12), transparent 28rem), linear-gradient(rgba(4,77,152,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(4,77,152,0.035) 1px, transparent 1px), #eaf1f8;
    background-size: auto, 36px 36px, 36px 36px, auto;
  }
  .portal-page {
    padding: clamp(1.25rem, 2.8vw, 2.8rem);
  }
  .portal-page, .portal-container, .portal-container > *, .portal-fragment .grid, .portal-fragment .grid > *, .portal-fragment section, .portal-fragment article {
    min-width: 0;
    max-width: 100%;
  }
  .portal-fragment :where(p, h1, h2, h3, li, td, th) {
    overflow-wrap: anywhere;
  }
  .portal-fragment svg {
    max-width: 100%;
  }
  .page-header {
    --page-banner-image: none;
    position: relative;
    overflow: hidden;
    height: 19rem;
    min-height: 19rem;
    align-items: center;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 3.5vw, 3rem);
    background-color: #062c56;
    background-image: linear-gradient(90deg, rgba(6,44,86,0.98) 0%, rgba(6,44,86,0.9) 39%, rgba(6,44,86,0.58) 64%, rgba(6,44,86,0.12) 100%), linear-gradient(180deg, rgba(4,28,55,0.08), rgba(4,28,55,0.34)), var(--page-banner-image);
    background-position: center, center, center right;
    background-repeat: no-repeat;
    background-size: cover;
    box-shadow: 0 24px 60px rgba(6,44,86,0.22);
    isolation: isolate;
  }
  .page-header::before, .page-header::after {
    display: none;
  }
  .page-heading-group {
    position: relative;
    z-index: 1;
    max-width: min(68%, 58rem);
  }
  .page-inicio .page-header {
    --page-banner-image: url("banners/inicio.webp");
  }
  .page-reportes .page-header {
    --page-banner-image: url("banners/reportes.webp");
  }
  .page-mapas .page-header {
    --page-banner-image: url("banners/territorio.webp");
  }
  .page-calendario .page-header {
    --page-banner-image: url("banners/agenda.webp");
  }
  .page-cedula .page-header {
    --page-banner-image: url("banners/cedula.webp");
  }
  .page-mision .page-header {
    --page-banner-image: url("banners/mision.webp");
  }
  .page-title {
    max-width: 18ch;
    color: #fff;
    font-size: clamp(2.15rem, 5vw, 4.1rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .page-subtitle {
    max-width: 58ch;
    color: rgba(255,255,255,0.82);
    font-size: var(--text-lead);
    line-height: 1.6;
  }
  .cutoff-badge {
    position: relative;
    z-index: 1;
    border-color: rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.65);
    backdrop-filter: blur(10px);
  }
  .cutoff-badge strong {
    color: #fff;
  }
  .panel, .portal-fragment .bg-white.border.border-gray-200.rounded-lg {
    border: 1px solid rgba(6,44,86,0.1);
    border-radius: 1rem;
    background: rgba(255,255,255,0.94);
    box-shadow: 0 14px 36px rgba(6,44,86,0.07);
  }
  .section-title {
    font-size: 1.12rem;
    font-weight: 850;
    letter-spacing: -0.025em;
  }
  .section-note {
    line-height: 1.45;
  }
  .portal-container > * {
    animation: portal-rise-in 520ms var(--portal-ease) both;
  }
  .portal-container > *:nth-child(2) {
    animation-delay: 55ms;
  }
  .portal-container > *:nth-child(3) {
    animation-delay: 105ms;
  }
  .portal-container > *:nth-child(4) {
    animation-delay: 155ms;
  }
  .portal-container > *:nth-child(n+5) {
    animation-delay: 190ms;
  }
  .portal-fragment svg[id$="chart"], .portal-fragment svg[id^="meter-"] {
    animation: chart-focus-in 680ms 180ms var(--portal-ease) both;
    transform-origin: center bottom;
  }
  .page-inicio .portal-container > .grid > section:first-child {
    border-top: 5px solid var(--color-brand-blue);
  }
  .page-inicio .portal-container > .grid > section:nth-child(2) {
    background: linear-gradient(155deg, #f8fcff, #e7f2fb);
    border-color: #b6cee3;
  }
  .page-inicio .data-number.text-\[clamp\(3\.25rem\,8vw\,5\.6rem\)\] {
    text-shadow: 0 10px 30px rgba(4,77,152,0.16);
  }
  .page-inicio #donut-wrap {
    border: 1px solid #c4d9eb;
    background: #edf6fd;
  }
  .page-inicio #chalecos-chart-wrap {
    border-radius: 0.8rem;
    background: linear-gradient(180deg, #f7fbff, #fff);
    padding: 0.5rem;
  }
  .page-reportes .portal-container > div:nth-of-type(1) {
    background: linear-gradient(120deg, #044d98, #0a6ab7);
    box-shadow: 0 20px 50px rgba(4,77,152,0.2);
  }
  .page-reportes .portal-container > div:nth-of-type(1) > .grid > div {
    border: 0;
  }
  .page-reportes .portal-container > div:nth-of-type(2), .page-reportes .portal-container > div:nth-of-type(3) {
    border-left: 5px solid #29a7d9;
  }
  .page-reportes .portal-container > div:nth-of-type(4) {
    background: #eaf4fc;
  }
  .page-reportes .portal-container > .grid > div {
    min-width: 0;
  }
  .page-reportes svg[id$="chart"] {
    filter: drop-shadow(0 8px 16px rgba(4,77,152,0.08));
  }
  .page-reportes svg[id$="chart"] rect {
    transform-box: fill-box;
    transform-origin: center bottom;
    animation: chart-bar-grow 620ms 220ms var(--portal-ease) both;
  }
  .page-reportes #cobertura-chart rect {
    transform-origin: left center;
    animation-name: chart-bar-grow-x;
  }
  .page-reportes svg[id$="chart"] circle {
    transform-box: fill-box;
    transform-origin: center;
    animation: chart-dot-in 420ms 360ms var(--portal-ease) both;
  }
  .method-disclosure {
    border-left: 5px solid #29a7d9 !important;
  }
  .method-disclosure summary::marker {
    content: "";
  }
  .method-disclosure__action {
    flex: none;
    border-radius: 0.55rem;
    background: var(--color-brand-blue);
    padding: 0.55rem 0.75rem;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    transition: transform 140ms var(--portal-ease), background-color 160ms ease;
  }
  .method-disclosure[open] .method-disclosure__action {
    background: #082f59;
  }
  .page-mapas #map-canvas {
    min-height: 30rem;
    border: 0;
    background-image: radial-gradient(circle at 30% 35%, rgba(41,167,217,0.24), transparent 12rem), linear-gradient(rgba(4,77,152,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(4,77,152,0.06) 1px, transparent 1px) !important;
    box-shadow: inset 0 0 0 1px #aac8df, inset 0 -80px 100px rgba(4,77,152,0.08);
  }
  .territory-kpis {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }
  .territory-kpi {
    position: relative;
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr);
    align-items: center;
    gap: 0.9rem;
    min-height: 8rem;
    overflow: hidden;
    border: 1px solid #d6e0e9;
    border-radius: 0.85rem;
    background: rgba(255,255,255,0.96);
    padding: 1rem 1.1rem;
    box-shadow: 0 8px 24px rgba(6,44,86,0.06);
  }
  .territory-kpi__icon {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border-radius: 0.75rem;
    background: #edf3f8;
    color: #52667b;
  }
  .territory-kpi__icon svg {
    width: 1.45rem;
    height: 1.45rem;
  }
  .territory-kpi__label {
    color: #52667b;
    font-size: var(--text-meta);
    font-weight: 750;
    line-height: 1.3;
  }
  .territory-kpi__metric {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 0.2rem;
  }
  .territory-kpi__metric strong {
    color: var(--color-portal-ink);
    font-family: var(--font-data);
    font-size: 2rem;
    font-weight: 650;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .territory-kpi__metric span {
    color: #52667b;
    font-size: var(--text-secondary);
    font-weight: 650;
  }
  .territory-kpi__meta {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    margin-top: 0.55rem;
    color: #68798b;
    font-size: var(--text-meta);
    line-height: 1.35;
  }
  .territory-kpi__meta i {
    width: 0.4rem;
    height: 0.4rem;
    flex: none;
    border-radius: 50%;
    background: #91a2b3;
  }
  .territory-kpi--active {
    border-color: #bdd3e6;
    box-shadow: 0 10px 28px rgba(4,77,152,0.09);
  }
  .territory-kpi--active .territory-kpi__icon {
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .territory-kpi--active .territory-kpi__metric strong {
    color: var(--color-brand-blue);
  }
  .territory-kpi--active .territory-kpi__meta i {
    background: #259b76;
    box-shadow: 0 0 0 3px rgba(37,155,118,0.12);
  }
  .territory-kpi--attention {
    border-color: #ead3ad;
    background: linear-gradient(145deg, #fffdfa, #fff8ec);
  }
  .territory-kpi--attention .territory-kpi__icon {
    background: #fff1d9;
    color: var(--color-portal-attention);
  }
  .territory-kpi--attention .territory-kpi__label, .territory-kpi--attention .territory-kpi__metric strong {
    color: var(--color-portal-attention);
  }
  .territory-kpi--attention .territory-kpi__meta i {
    background: #d58a24;
  }
  .page-mapas .map-pin .pin-dot {
    box-shadow: 0 0 0 6px rgba(4,77,152,0.12), 0 8px 20px rgba(4,77,152,0.3);
    animation: pin-arrive 480ms var(--portal-ease) both;
  }
  .page-mapas .map-pin:nth-of-type(2) .pin-dot {
    animation-delay: 80ms;
  }
  .page-mapas .map-pin:nth-of-type(3) .pin-dot {
    animation-delay: 140ms;
  }
  .page-mapas .map-pin:nth-of-type(4) .pin-dot {
    animation-delay: 200ms;
  }
  .page-mapas #ranking-list {
    scrollbar-color: #9bbad5 transparent;
    scrollbar-width: thin;
  }
  .page-calendario .lg\:grid-cols-3 > div:first-child {
    border-top: 5px solid #29a7d9;
  }
  .page-calendario #calendar-grid {
    gap: 0.35rem;
  }
  .page-calendario .day-cell {
    font-family: var(--font-data);
  }
  .page-calendario .day-cell[data-today="true"] {
    box-shadow: 0 9px 22px rgba(4,77,152,0.26);
  }
  .page-calendario .space-y-4 > div:first-child {
    background: linear-gradient(135deg, #044d98, #0b6fbd);
    box-shadow: 0 16px 36px rgba(4,77,152,0.2);
  }
  .cedula-layout, .mission-layout {
    display: grid;
    gap: clamp(1rem, 1.8vw, 1.5rem);
  }
  .cedula-intro {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(20rem, 0.92fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    min-height: 27rem;
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 4vw, 3.75rem);
    background: linear-gradient(125deg, #082f59 0%, #075ea9 68%, #0b79c6 100%);
    box-shadow: 0 26px 58px rgba(6,44,86,0.22);
  }
  .cedula-intro::before {
    content: "";
    position: absolute;
    z-index: -1;
    width: 30rem;
    aspect-ratio: 1;
    right: -10rem;
    top: -15rem;
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 50%;
    box-shadow: 0 0 0 4rem rgba(255,255,255,0.025), 0 0 0 9rem rgba(255,255,255,0.02);
  }
  .cedula-intro__copy {
    max-width: 39rem;
    color: #fff;
  }
  .cedula-intro__label, .cedula-sheet__head span, .capture-route__heading p, .cedula-signals header > p, .cedula-outcome__label, .mission-manifesto__label, .mission-manifesto__thesis > p:first-child, .mission-reach article > p:first-child, .mission-scale__heading > p {
    font-family: var(--font-data);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .cedula-intro__label {
    color: #8fd8f2;
  }
  .cedula-intro h2 {
    max-width: 15ch;
    margin-top: 1rem;
    color: #fff;
    font-size: clamp(2.35rem, 4.1vw, 4.35rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    text-wrap: balance;
  }
  .cedula-intro__copy > p:last-of-type {
    max-width: 34rem;
    margin-top: 1.25rem;
    color: rgba(255,255,255,0.76);
    font-size: 1rem;
    line-height: 1.65;
  }
  .cedula-cta {
    width: fit-content;
    margin-top: 2rem;
    display: inline-flex;
    align-items: center;
    gap: 1.35rem;
    border-radius: 0.75rem;
    background: #fff;
    padding: 0.85rem 0.9rem 0.85rem 1rem;
    color: #044d98;
    box-shadow: 0 14px 30px rgba(4,28,55,0.22);
    transition: transform 160ms var(--portal-ease), box-shadow 180ms ease, background-color 160ms ease;
  }
  .cedula-cta span {
    display: grid;
    gap: 0.1rem;
  }
  .cedula-cta strong {
    font-size: 0.92rem;
    line-height: 1.1;
  }
  .cedula-cta small {
    color: #627b93;
    font-size: 0.67rem;
  }
  .cedula-cta b {
    display: grid;
    place-items: center;
    width: 2.25rem;
    aspect-ratio: 1;
    border-radius: 0.55rem;
    background: #e8f3fb;
    font-size: 1.1rem;
  }
  .cedula-sheet {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.42);
    border-radius: 1rem;
    background: rgba(247,251,255,0.96);
    padding: 1.35rem;
    color: #10263d;
    box-shadow: 0 24px 55px rgba(4,29,57,0.24), inset 0 1px 0 #fff;
  }
  .cedula-sheet__head {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid #c8d9e8;
    padding-bottom: 1rem;
  }
  .cedula-sheet__head span {
    color: #0b6fbe;
  }
  .cedula-sheet__head strong {
    font-size: 0.92rem;
  }
  .cedula-sheet dl {
    position: relative;
    z-index: 1;
    display: grid;
    margin-top: 0.35rem;
  }
  .cedula-sheet dl div {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: 1rem;
    border-bottom: 1px solid #dce7f0;
    padding: 0.85rem 0;
  }
  .cedula-sheet dt {
    font-size: 0.82rem;
    font-weight: 800;
  }
  .cedula-sheet dd {
    color: #5a7086;
    font-size: 0.78rem;
  }
  .cedula-sheet__result {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
    border-radius: 0.65rem;
    background: #dceefb;
    padding: 0.85rem 1rem;
  }
  .cedula-sheet__result span {
    color: #647d93;
    font-size: 0.7rem;
  }
  .cedula-sheet__result strong {
    color: #044d98;
    font-size: 0.8rem;
    text-align: right;
  }
  .capture-route {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
    border-radius: 1rem;
    background: #fff;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    box-shadow: 0 14px 36px rgba(6,44,86,0.07);
  }
  .capture-route__heading h2 {
    max-width: 12ch;
    color: #10263d;
    font-size: clamp(1.75rem, 2.8vw, 2.65rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }
  .capture-route__heading p {
    max-width: 24rem;
    margin-top: 1rem;
    color: #63798e;
    line-height: 1.6;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
  }
  .capture-route__track {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .capture-route__track::before {
    content: "";
    position: absolute;
    left: 1.15rem;
    right: 1.15rem;
    top: 1.15rem;
    height: 1px;
    background: #a9c7df;
    transform: scaleX(0);
    transform-origin: left;
    animation: route-line-in 680ms 240ms var(--portal-ease) forwards;
  }
  .capture-route__track article {
    position: relative;
    z-index: 1;
  }
  .capture-route__track article > span {
    display: grid;
    place-items: center;
    width: 2.3rem;
    aspect-ratio: 1;
    border: 5px solid #fff;
    border-radius: 50%;
    background: #0b6fbe;
    color: #fff;
    font-family: var(--font-data);
    font-size: 0.65rem;
    box-shadow: 0 0 0 1px #8eb8d8;
  }
  .capture-route__track h3 {
    margin-top: 1rem;
    color: #10263d;
    font-size: 1rem;
    font-weight: 850;
  }
  .capture-route__track p {
    margin-top: 0.3rem;
    color: #687e93;
    font-size: 0.78rem;
    line-height: 1.55;
  }
  .cedula-workbench {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(20rem, 0.88fr);
    gap: 1.25rem;
    align-items: stretch;
  }
  .cedula-signals, .cedula-outcome {
    border-radius: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }
  .cedula-signals {
    background: #fff;
    box-shadow: 0 14px 36px rgba(6,44,86,0.07);
  }
  .cedula-signals header > p {
    color: #0b6fbe;
  }
  .cedula-signals h2, .cedula-outcome h2 {
    max-width: 15ch;
    margin-top: 0.55rem;
    color: #10263d;
    font-size: clamp(1.65rem, 2.4vw, 2.35rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.08;
    text-wrap: balance;
  }
  .cedula-signals dl {
    margin-top: 1.7rem;
    border-top: 1px solid #bdd0e0;
  }
  .cedula-signals dl div {
    display: grid;
    grid-template-columns: minmax(8rem, 0.75fr) 1.25fr;
    gap: 1.25rem;
    border-bottom: 1px solid #e0e9f0;
    padding: 1rem 0;
  }
  .cedula-signals dt {
    color: #18324b;
    font-size: 0.85rem;
    font-weight: 800;
  }
  .cedula-signals dd {
    color: #667d92;
    font-size: 0.78rem;
    line-height: 1.5;
  }
  .cedula-outcome {
    position: relative;
    overflow: hidden;
    background: linear-gradient(145deg, #dceefa, #cce4f5);
  }
  .cedula-outcome::after {
    content: "";
    position: absolute;
    width: 12rem;
    aspect-ratio: 1;
    right: -6rem;
    bottom: -6rem;
    border: 1px solid rgba(4,77,152,0.15);
    border-radius: 50%;
    box-shadow: 0 0 0 2.6rem rgba(255,255,255,0.18);
  }
  .cedula-outcome > * {
    position: relative;
    z-index: 1;
  }
  .cedula-outcome__label {
    color: #0b6fbe;
  }
  .cedula-outcome ol {
    display: grid;
    gap: 0.65rem;
    margin-top: 1.5rem;
    counter-reset: outcome;
  }
  .cedula-outcome li {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.12rem;
    border-left: 3px solid #0b6fbe;
    background: rgba(255,255,255,0.56);
    padding: 0.8rem 1rem;
  }
  .cedula-outcome li strong {
    color: #18324b;
    font-size: 0.83rem;
  }
  .cedula-outcome li span {
    color: #60788f;
    font-size: 0.74rem;
    line-height: 1.45;
  }
  .cedula-programs {
    margin-top: 1.5rem;
    border-top: 1px solid rgba(4,77,152,0.2);
    padding-top: 1rem;
  }
  .cedula-programs > p {
    color: #496b88;
    font-size: 0.7rem;
    font-weight: 800;
  }
  .cedula-programs > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.65rem;
  }
  .cedula-programs span {
    border: 1px solid rgba(4,77,152,0.2);
    border-radius: 0.4rem;
    background: rgba(255,255,255,0.6);
    padding: 0.4rem 0.55rem;
    color: #315573;
    font-size: 0.68rem;
  }
  .mission-manifesto {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(19rem, 0.85fr);
    overflow: hidden;
    border: 1px solid #b9cfe0;
    border-radius: 1.25rem;
    background: #f2f8fc;
    box-shadow: 0 18px 44px rgba(6,44,86,0.09);
  }
  .mission-manifesto__quote {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 24rem;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: clamp(1.75rem, 4vw, 3.5rem);
  }
  .mission-manifesto__quote::before {
    content: "\201C";
    position: absolute;
    z-index: -1;
    right: 2rem;
    top: -4.5rem;
    color: rgba(4,77,152,0.07);
    font-family: Georgia, serif;
    font-size: 18rem;
    line-height: 1;
  }
  .mission-manifesto__label {
    color: #0b6fbe;
  }
  .mission-manifesto blockquote {
    max-width: 18ch;
    color: #0a3764;
    font-size: clamp(2.1rem, 4vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    text-wrap: balance;
  }
  .mission-manifesto__source {
    color: #60788f;
    font-size: 0.72rem;
    line-height: 1.55;
  }
  .mission-manifesto__thesis {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(145deg, #082f59, #075ea9);
    padding: clamp(1.75rem, 4vw, 3.5rem);
    color: #fff;
  }
  .mission-manifesto__thesis > p:first-child {
    color: #8fd8f2;
  }
  .mission-manifesto__thesis h2 {
    margin-top: 0.85rem;
    font-size: clamp(1.9rem, 2.8vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.02;
  }
  .mission-manifesto__thesis > p:nth-of-type(2) {
    margin-top: 1.2rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.88rem;
    line-height: 1.65;
  }
  .mission-manifesto__signal {
    display: grid;
    gap: 0.55rem;
    margin-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 1rem;
  }
  .mission-manifesto__signal span {
    color: rgba(255,255,255,0.82);
    font-size: 0.74rem;
    font-weight: 750;
  }
  .mission-path {
    border-radius: 1rem;
    background: #fff;
    padding: clamp(1.5rem, 3vw, 2.6rem);
    box-shadow: 0 14px 36px rgba(6,44,86,0.07);
  }
  .mission-path > header {
    max-width: 46rem;
  }
  .mission-path h2 {
    color: #10263d;
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 1.04;
  }
  .mission-path > header p {
    max-width: 40rem;
    margin-top: 0.8rem;
    color: #667d92;
    font-size: 0.86rem;
    line-height: 1.6;
  }
  .mission-path__rows {
    margin-top: 2rem;
    border-top: 1px solid #abc6da;
  }
  .mission-path__rows article {
    display: grid;
    grid-template-columns: 0.55fr 1.25fr 0.65fr;
    gap: 1.25rem;
    align-items: center;
    border-bottom: 1px solid #dfe8ef;
    padding: 1.05rem 0.75rem;
    transition: transform 160ms var(--portal-ease), background-color 160ms ease;
  }
  .mission-path__rows strong {
    color: #0b6fbe;
    font-size: 1rem;
  }
  .mission-path__rows p {
    color: #354e66;
    font-size: 0.82rem;
  }
  .mission-path__rows span {
    color: #71879a;
    font-family: var(--font-data);
    font-size: 0.65rem;
    text-align: right;
  }
  .mission-reach {
    display: grid;
    grid-template-columns: minmax(18rem, 0.85fr) minmax(0, 1.15fr);
    gap: 1.25rem;
  }
  .mission-audience, .mission-services {
    border-radius: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }
  .mission-audience {
    background: linear-gradient(145deg, #dceefa, #cce4f5);
  }
  .mission-audience > p, .mission-services > p {
    color: #0b6fbe;
  }
  .mission-audience h2 {
    max-width: 15ch;
    margin-top: 0.7rem;
    color: #102f4b;
    font-size: clamp(1.7rem, 2.6vw, 2.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.07;
  }
  .mission-audience ul {
    display: grid;
    margin-top: 1.6rem;
    border-top: 1px solid rgba(4,77,152,0.2);
  }
  .mission-audience li {
    display: grid;
    gap: 0.1rem;
    border-bottom: 1px solid rgba(4,77,152,0.16);
    padding: 0.85rem 0;
  }
  .mission-audience li strong {
    color: #183d5d;
    font-size: 0.82rem;
  }
  .mission-audience li span {
    color: #5d7890;
    font-size: 0.73rem;
  }
  .mission-services {
    background: #fff;
    box-shadow: 0 14px 36px rgba(6,44,86,0.07);
  }
  .mission-services > div {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1.25rem;
  }
  .mission-services section {
    min-height: 8rem;
    padding: 1.2rem;
  }
  .mission-services section:nth-child(odd) {
    border-right: 1px solid #dce7ef;
  }
  .mission-services section:nth-child(-n+2) {
    border-bottom: 1px solid #dce7ef;
  }
  .mission-services h3 {
    color: #17344e;
    font-size: 1rem;
    font-weight: 850;
  }
  .mission-services section p {
    max-width: 20ch;
    margin-top: 0.45rem;
    color: #687f93;
    font-size: 0.76rem;
    line-height: 1.5;
  }
  .mission-scale {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    border-radius: 1.25rem;
    background: #dceefa;
    padding: clamp(1.5rem, 3vw, 2.75rem);
  }
  .mission-scale__heading > p {
    color: #0b6fbe;
  }
  .mission-scale__heading h2 {
    max-width: 13ch;
    margin-top: 0.65rem;
    color: #102f4b;
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.04;
  }
  .mission-scale__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-self: start;
    overflow: hidden;
    border-radius: 0.85rem;
    background: #fff;
    box-shadow: 0 12px 30px rgba(6,44,86,0.08);
  }
  .mission-scale__metrics article {
    display: grid;
    align-content: start;
    padding: 1.35rem;
  }
  .mission-scale__metrics article + article {
    border-left: 1px solid #dce7ef;
  }
  .mission-scale__metrics strong, .mission-scale__programs strong {
    color: #044d98;
    font-family: var(--font-data);
    font-size: clamp(1.65rem, 2.6vw, 2.6rem);
    letter-spacing: -0.035em;
  }
  .mission-scale__metrics span {
    margin-top: 0.45rem;
    color: #233f58;
    font-size: 0.78rem;
    font-weight: 800;
  }
  .mission-scale__metrics small {
    margin-top: 0.25rem;
    color: #71869a;
    font-size: 0.68rem;
  }
  .mission-scale__programs {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid rgba(4,77,152,0.2);
    padding-top: 1.4rem;
  }
  .mission-scale__programs article {
    display: grid;
    grid-template-columns: minmax(8rem, 0.65fr) minmax(8rem, 0.55fr) 1.1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.8rem 0;
  }
  .mission-scale__programs article + article {
    border-top: 1px solid rgba(4,77,152,0.14);
  }
  .mission-scale__programs span {
    color: #264a67;
    font-size: 0.82rem;
    font-weight: 850;
  }
  .mission-scale__programs strong {
    font-size: 1.4rem;
  }
  .mission-scale__programs p {
    color: #4f6a81;
    font-size: var(--text-secondary);
    line-height: 1.55;
  }
  .portal-shell, .portal-fragment {
    font-size: var(--text-body);
    font-kerning: normal;
    font-optical-sizing: auto;
  }
  .portal-fragment :where(p, li, dd) {
    text-wrap: pretty;
  }
  .portal-fragment :where(h1, h2, h3) {
    text-wrap: balance;
  }
  .portal-brand strong {
    font-size: 1rem;
    line-height: 1.2;
  }
  .portal-brand small {
    font-size: var(--text-caption);
    line-height: 1.35;
  }
  .portal-desktop-nav > a, .portal-dropdown__trigger {
    font-size: 0.9375rem;
  }
  .portal-dropdown__item strong {
    font-size: 0.9375rem;
    line-height: 1.3;
  }
  .portal-dropdown__item small {
    color: #607085;
    font-size: var(--text-meta);
    line-height: 1.4;
  }
  .portal-live-status {
    font-size: var(--text-caption);
    line-height: 1.2;
  }
  .portal-live-status strong {
    font-size: var(--text-caption);
  }
  .portal-mobile-menu__head small {
    font-size: var(--text-caption);
  }
  .portal-mobile-menu__head strong {
    font-size: 1.25rem;
  }
  .portal-mobile-menu__nav a > span {
    font-size: var(--text-caption);
  }
  .portal-mobile-menu__nav a strong {
    font-size: 1.0625rem;
    line-height: 1.3;
  }
  .portal-mobile-menu__nav a small {
    color: rgba(255,255,255,0.74);
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .portal-mobile-menu__foot span {
    color: rgba(255,255,255,0.74);
    font-size: var(--text-meta);
    line-height: 1.45;
  }
  .portal-mobile-menu__foot strong {
    font-size: 1.125rem;
  }
  .page-kicker {
    font-size: var(--text-meta);
    line-height: 1.35;
  }
  .cutoff-badge {
    font-size: var(--text-meta);
    line-height: 1.45;
  }
  .section-title {
    font-size: var(--text-section);
    line-height: 1.3;
  }
  .section-note {
    max-width: 72ch;
    color: #506176;
    font-size: var(--text-body);
    line-height: 1.6;
  }
  .status-chip {
    min-height: 2rem;
    font-size: var(--text-meta);
    line-height: 1.35;
  }
  .method-disclosure__action {
    font-size: var(--text-meta);
  }
  .portal-fragment .text-xs {
    font-size: var(--text-meta);
    line-height: 1.45;
  }
  .portal-fragment .text-sm {
    font-size: var(--text-secondary);
    line-height: 1.55;
  }
  .portal-fragment .text-base {
    font-size: var(--text-body);
    line-height: 1.6;
  }
  .portal-fragment :where(.text-gray-500, .text-portal-muted) {
    color: #506176;
  }
  .territory-cell {
    font-size: var(--text-caption);
  }
  .page-reportes svg[id$="chart"] text {
    fill: #41566b;
    font-family: var(--font-sans);
    font-size: var(--text-meta) !important;
    font-weight: 650;
  }
  .page-reportes svg[id$="chart"] .font-data {
    font-family: var(--font-data);
  }
  .cedula-intro__label, .cedula-sheet__head span, .cedula-signals header > p, .cedula-outcome__label, .mission-manifesto__label, .mission-manifesto__thesis > p:first-child, .mission-reach article > p:first-child, .mission-scale__heading > p {
    font-size: var(--text-meta);
    line-height: 1.4;
  }
  .cedula-intro__copy > p:last-of-type {
    font-size: var(--text-body);
  }
  .cedula-cta strong, .cedula-sheet__head strong {
    font-size: 1rem;
  }
  .cedula-cta small {
    color: #4f657b;
    font-size: var(--text-meta);
  }
  .cedula-sheet dt, .cedula-signals dt, .cedula-outcome li strong {
    font-size: var(--text-secondary);
    line-height: 1.45;
  }
  .cedula-sheet dd, .capture-route__track p, .cedula-signals dd, .cedula-outcome li span {
    color: #4f657b;
    font-size: 0.875rem;
    line-height: 1.55;
  }
  .cedula-sheet__result span, .cedula-programs > p, .cedula-programs span {
    font-size: var(--text-meta);
  }
  .cedula-sheet__result strong {
    font-size: 0.875rem;
  }
  .capture-route__heading p {
    color: #50687d;
    font-size: var(--text-body);
    line-height: 1.6;
  }
  .capture-route__track article > span {
    font-size: var(--text-caption);
  }
  .capture-route__track h3 {
    font-size: 1.0625rem;
  }
  .mission-manifesto__source {
    color: #4f687e;
    font-size: var(--text-meta);
    line-height: 1.55;
  }
  .mission-manifesto__thesis > p:nth-of-type(2) {
    color: rgba(255,255,255,0.82);
    font-size: var(--text-body);
    line-height: 1.7;
  }
  .mission-manifesto__signal span {
    color: rgba(255,255,255,0.9);
    font-size: 0.875rem;
  }
  .mission-path > header p {
    color: #50687d;
    font-size: var(--text-body);
    line-height: 1.6;
  }
  .mission-path__rows strong {
    font-size: 1.0625rem;
  }
  .mission-path__rows p {
    font-size: var(--text-secondary);
    line-height: 1.5;
  }
  .mission-path__rows span {
    color: #587086;
    font-size: var(--text-meta);
    line-height: 1.45;
  }
  .mission-audience li strong {
    font-size: var(--text-secondary);
  }
  .mission-audience li span {
    color: #4f6a81;
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .mission-services h3 {
    font-size: 1.0625rem;
  }
  .mission-services section p {
    max-width: 28ch;
    color: #50687d;
    font-size: 0.875rem;
    line-height: 1.55;
  }
  .mission-scale__metrics span, .mission-scale__programs span {
    font-size: var(--text-secondary);
    line-height: 1.45;
  }
  .mission-scale__metrics small {
    color: #526c83;
    font-size: var(--text-meta);
    line-height: 1.45;
  }
}
@keyframes route-line-in {
  from {
    opacity: 0;
    transform: scaleX(0);
  }
  to {
    opacity: 1;
    transform: scaleX(1);
  }
}
@keyframes portal-rise-in {
  from {
    opacity: 0;
    transform: translateY(14px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
@keyframes chart-focus-in {
  from {
    opacity: 0;
    transform: translateY(8px) scaleY(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scaleY(1);
  }
}
@keyframes pin-arrive {
  from {
    opacity: 0;
    transform: translateY(-12px) scale(0.84);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
@keyframes chart-bar-grow {
  from {
    opacity: 0;
    transform: scaleY(0.08);
  }
  to {
    opacity: 1;
    transform: scaleY(1);
  }
}
@keyframes chart-bar-grow-x {
  from {
    opacity: 0;
    transform: scaleX(0.08);
  }
  to {
    opacity: 1;
    transform: scaleX(1);
  }
}
@keyframes chart-dot-in {
  from {
    opacity: 0;
    transform: scale(0.75);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
@media (hover: hover) and (pointer: fine) {
  .portal-desktop-nav > a:hover {
    color: var(--color-brand-blue);
    background: rgba(255,255,255,0.78);
  }
  .portal-brand:hover .portal-brand__mark {
    transform: translateY(-1px) rotate(-2deg);
  }
  .portal-brand__mark {
    transition: transform 180ms var(--portal-ease), box-shadow 180ms ease;
  }
  .portal-dropdown__item:hover {
    transform: translateX(2px);
  }
  .panel:hover {
    border-color: rgba(4,77,152,0.2);
    box-shadow: 0 18px 44px rgba(6,44,86,0.09);
  }
  .cedula-cta:hover {
    transform: translateY(-2px);
    background: #f4faff;
    box-shadow: 0 18px 36px rgba(4,28,55,0.28);
  }
  .mission-path__rows article:hover {
    transform: translateX(3px);
    background: #f2f8fc;
  }
}
.cedula-cta:active {
  transform: scale(0.98);
}
@media (max-width: 1023px) {
  .portal-commandbar__inner {
    grid-template-columns: 1fr auto;
    min-height: 4.4rem;
  }
  .portal-desktop-nav {
    display: none;
  }
  .portal-menu-button {
    position: relative;
    display: grid;
  }
  .portal-live-status span {
    display: none;
  }
}
@media (max-width: 767px) {
  .portal-commandbar__inner {
    width: min(100% - 1.25rem, 92rem);
    gap: 0.75rem;
  }
  .portal-brand__mark {
    width: 2.25rem;
    height: 2.25rem;
  }
  .portal-brand small {
    display: none;
  }
  .portal-live-status {
    display: none;
  }
  .page-header {
    height: 22rem;
    min-height: 22rem;
    border-radius: 1rem;
    padding: 1.35rem;
    background-image: linear-gradient(90deg, rgba(6,44,86,0.96), rgba(6,44,86,0.72)), linear-gradient(180deg, rgba(4,28,55,0.08), rgba(4,28,55,0.38)), var(--page-banner-image);
    background-position: center, center, 68% center;
  }
  .page-heading-group {
    max-width: 100%;
  }
  .page-title {
    font-size: clamp(2rem, 11vw, 3.15rem);
  }
  .page-header::after {
    display: none;
  }
  .cutoff-badge {
    font-size: var(--text-caption);
  }
  .territory-kpis {
    grid-template-columns: 1fr;
  }
  .territory-kpi {
    min-height: 7.25rem;
  }
  .page-mapas #map-canvas {
    width: 100%;
    min-height: 22rem;
    aspect-ratio: auto !important;
  }
  .portal-container > * {
    animation-duration: 420ms;
  }
}
@media (max-width: 900px) {
  .cedula-intro, .cedula-workbench, .capture-route, .mission-manifesto, .mission-reach, .mission-scale {
    grid-template-columns: 1fr;
  }
  .cedula-intro {
    min-height: auto;
  }
  .cedula-intro h2 {
    max-width: 15ch;
  }
  .cedula-sheet {
    width: min(100%, 38rem);
  }
  .capture-route {
    align-items: start;
  }
  .capture-route__heading h2 {
    max-width: none;
  }
  .mission-manifesto__quote {
    min-height: 21rem;
  }
  .mission-scale__programs {
    grid-column: auto;
  }
}
@media (max-width: 599px) {
  .cedula-intro, .capture-route, .cedula-signals, .cedula-outcome, .mission-manifesto__quote, .mission-manifesto__thesis, .mission-path, .mission-audience, .mission-services, .mission-scale {
    border-radius: 0.9rem;
    padding: 1.25rem;
  }
  .cedula-intro h2 {
    font-size: clamp(2.15rem, 11vw, 3.25rem);
  }
  .page-cedula .page-title {
    overflow-wrap: normal;
    font-size: clamp(1.8rem, 8.4vw, 2.1rem);
    hyphens: none;
    word-break: normal;
  }
  .cedula-sheet {
    padding: 1rem;
  }
  .cedula-sheet dl div, .cedula-signals dl div {
    grid-template-columns: 1fr;
    gap: 0.25rem;
  }
  .cedula-sheet__head, .cedula-sheet__result {
    align-items: flex-start;
    flex-direction: column;
  }
  .cedula-sheet__result strong {
    text-align: left;
  }
  .capture-route__track {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .capture-route__track::before {
    display: none;
  }
  .capture-route__track article {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.8rem;
    align-items: center;
  }
  .capture-route__track article > span {
    grid-row: span 2;
  }
  .capture-route__track h3, .capture-route__track p {
    margin-top: 0;
  }
  .mission-manifesto__quote {
    min-height: 19rem;
  }
  .mission-manifesto blockquote {
    font-size: clamp(2rem, 10vw, 3rem);
  }
  .mission-path__rows article {
    grid-template-columns: 1fr;
    gap: 0.3rem;
    padding-inline: 0;
  }
  .mission-path__rows span {
    text-align: left;
  }
  .mission-services > div, .mission-scale__metrics, .mission-scale__programs {
    grid-template-columns: 1fr;
  }
  .mission-services section {
    min-height: auto;
    border-right: 0 !important;
    border-bottom: 1px solid #dce7ef;
    padding-inline: 0;
  }
  .mission-services section:last-child {
    border-bottom: 0;
  }
  .mission-scale__metrics article + article {
    border-top: 1px solid #dce7ef;
    border-left: 0;
  }
  .mission-scale__programs article {
    grid-template-columns: 1fr;
    gap: 0.25rem;
  }
}
@media (prefers-reduced-motion: reduce) {
  .portal-container > *, .portal-fragment svg[id$="chart"], .portal-fragment svg[id^="meter-"], .page-mapas .map-pin .pin-dot, .page-reportes svg[id$="chart"] rect, .page-reportes svg[id$="chart"] circle, .capture-route__track::before {
    animation: none !important;
  }
  .capture-route__track::before {
    opacity: 1;
    transform: scaleX(1);
  }
  .portal-mobile-menu__nav a {
    opacity: 1;
    transform: none;
  }
}
@layer base {
  :root {
    color-scheme: light;
    --portal-shadow-floating: 0 18px 48px rgba(6, 44, 86, 0.18);
    --portal-shadow-interactive: 0 8px 20px rgba(6, 44, 86, 0.1);
    --portal-ease: cubic-bezier(0.23, 1, 0.32, 1);
    --portal-ease-drawer: cubic-bezier(0.32, 0.72, 0, 1);
  }
  html {
    background: var(--color-portal-canvas);
    scroll-behavior: smooth;
  }
  body {
    font-family: var(--font-sans);
    color: var(--color-portal-ink);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }
  ::selection {
    background: var(--color-portal-blue-soft);
    color: var(--color-brand-navy);
  }
  :where(a, button, input, select, textarea, summary):focus-visible {
    outline: 3px solid #91b3d7;
    outline-offset: 2px;
  }
  button, summary, a {
    -webkit-tap-highlight-color: transparent;
  }
  svg text, .tabular-nums {
    font-variant-numeric: tabular-nums;
  }
}
@layer components {
  .portal-shell {
    background: var(--color-portal-canvas);
    color: var(--color-portal-ink);
  }
  .app-sidebar {
    background: var(--color-brand-navy);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 1px 0 0 rgba(255, 255, 255, 0.04);
    transition-timing-function: var(--portal-ease-drawer);
  }
  .app-sidebar .sidebar-brand {
    border-color: rgba(255, 255, 255, 0.12);
  }
  .app-sidebar nav a {
    position: relative;
    color: rgba(255, 255, 255, 0.7);
    border-radius: 0.5rem;
  }
  .app-sidebar nav a:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }
  .app-sidebar nav a[data-active] {
    background: #fff;
    color: var(--color-brand-blue);
  }
  .app-sidebar .sidebar-foot {
    border-color: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.56);
  }
  .app-topbar {
    background: rgba(255, 255, 255, 0.96);
    border-color: var(--color-portal-line);
  }
  .portal-fragment {
    min-height: 100%;
    overflow-x: hidden;
    background: linear-gradient(rgba(4, 77, 152, 0.028) 1px, transparent 1px), linear-gradient(90deg, rgba(4, 77, 152, 0.028) 1px, transparent 1px), var(--color-portal-canvas);
    background-size: 32px 32px;
    color: var(--color-portal-ink);
  }
  .portal-page {
    padding: clamp(1.1rem, 2.4vw, 2.2rem);
  }
  .portal-container {
    width: min(100%, 84rem);
    margin-inline: auto;
  }
  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
    padding-block: 0.25rem 0.5rem;
  }
  .page-heading-group {
    min-width: 0;
  }
  .page-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-brand-blue);
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.02em;
  }
  .page-kicker::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border: 1px solid currentColor;
    border-radius: 2px;
    background: var(--color-portal-blue-open);
  }
  .page-title {
    margin-top: 0.35rem;
    color: var(--color-portal-ink);
    font-size: clamp(1.65rem, 2.4vw, 2.15rem);
    font-weight: 850;
    line-height: 1.08;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .page-subtitle {
    margin-top: 0.45rem;
    max-width: 72ch;
    color: var(--color-portal-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    text-wrap: pretty;
  }
  .cutoff-badge {
    flex: none;
    border: 1px solid var(--color-portal-line);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.76);
    padding: 0.55rem 0.7rem;
    color: var(--color-portal-muted);
    font-family: var(--font-data);
    font-size: 0.7rem;
    line-height: 1.3;
    text-align: right;
  }
  .panel {
    border: 1px solid var(--color-portal-line);
    border-radius: 0.75rem;
    background: var(--color-portal-surface);
    padding: clamp(1rem, 2vw, 1.5rem);
  }
  .panel--quiet {
    background: rgba(255, 255, 255, 0.72);
  }
  .panel--ink {
    border-color: var(--color-brand-navy);
    background: var(--color-brand-navy);
    color: #fff;
  }
  .section-title {
    color: var(--color-portal-ink);
    font-size: 1.05rem;
    font-weight: 780;
    line-height: 1.3;
    letter-spacing: -0.012em;
  }
  .section-note {
    margin-top: 0.3rem;
    max-width: 72ch;
    color: var(--color-portal-muted);
    font-size: 0.86rem;
    line-height: 1.5;
    text-wrap: pretty;
  }
  .data-number {
    font-family: var(--font-data);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.035em;
  }
  .status-chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    border: 1px solid var(--color-portal-line);
    border-radius: 0.4rem;
    background: #fff;
    padding-inline: 0.55rem;
    color: var(--color-portal-muted);
    font-size: 0.72rem;
    font-weight: 700;
  }
  .status-chip--real {
    border-color: #aec7df;
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .status-chip--projected {
    border-style: dashed;
    color: var(--color-portal-ink);
  }
  .attention-note {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    border: 1px solid #e8c991;
    border-radius: 0.65rem;
    background: var(--color-portal-attention-open);
    padding: 0.9rem 1rem;
    color: #6f4210;
  }
  .attention-note strong {
    color: #5c3509;
  }
  .territory-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.35rem;
  }
  .territory-cell {
    aspect-ratio: 1;
    min-height: 2.75rem;
    min-width: 0;
    border: 1px solid var(--color-portal-line);
    border-radius: 0.35rem;
    background: #fff;
    color: #7c8795;
    font-family: var(--font-data);
    font-size: 0.58rem;
    font-weight: 650;
    transition: transform 180ms var(--portal-ease), background 180ms var(--portal-ease), color 180ms var(--portal-ease), border-color 180ms var(--portal-ease);
  }
  @media (min-width: 640px) {
    .territory-grid {
      grid-template-columns: repeat(10, minmax(0, 1fr));
    }
    .territory-cell {
      min-height: 0;
    }
  }
  .territory-cell[data-active="true"] {
    border-color: #94b7d7;
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .territory-cell[data-alert="true"] {
    border-color: #d8aa60;
    background: var(--color-portal-attention-open);
    color: var(--color-portal-attention);
  }
  .territory-cell:focus-visible {
    z-index: 1;
    border-color: var(--color-brand-blue);
    background: var(--color-brand-blue);
    color: #fff;
  }
  .portal-fragment table {
    font-variant-numeric: tabular-nums;
  }
  .portal-fragment thead {
    color: var(--color-portal-muted);
  }
  .portal-fragment tbody tr {
    transition: background 160ms var(--portal-ease);
  }
  .portal-fragment tbody tr:hover {
    background: var(--color-portal-blue-open);
  }
  .portal-fragment .bg-white.border.border-gray-200.rounded-lg {
    border-color: var(--color-portal-line);
    border-radius: 0.75rem;
    background: var(--color-portal-surface);
  }
  .portal-fragment .bg-gray-50 {
    background: var(--color-portal-blue-open);
  }
  .portal-fragment .bg-gray-900 {
    background: var(--color-brand-navy);
  }
  .portal-fragment .text-gray-900, .portal-fragment .text-gray-800, .portal-fragment .text-gray-700 {
    color: var(--color-portal-ink);
  }
  .portal-fragment .text-gray-600, .portal-fragment .text-gray-500, .portal-fragment .text-gray-400 {
    color: var(--color-portal-muted);
  }
  .portal-fragment .border-gray-200, .portal-fragment .border-gray-100, .portal-fragment .divide-gray-100 > :not(:last-child) {
    border-color: var(--color-portal-line);
  }
  .portal-fragment :where(button, a, summary) {
    transition-duration: 180ms;
    transition-timing-function: var(--portal-ease);
    touch-action: manipulation;
  }
  .portal-fragment :where(.territory-cell, .day-cell, .tab-btn, .map-pin, #ranking-list button):active {
    scale: 0.98;
    transition-duration: 120ms;
  }
  @media (hover: hover) and (pointer: fine) {
    .territory-cell:hover {
      z-index: 1;
      border-color: var(--color-brand-blue);
      background: var(--color-brand-blue);
      color: #fff;
      transform: translateY(-1px);
    }
    .map-pin:hover .pin-dot {
      scale: 1.1;
    }
  }
  .portal-fragment summary {
    border-radius: 0.35rem;
  }
  .portal-tooltip {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: var(--color-brand-navy);
    box-shadow: var(--portal-shadow-floating);
  }
  @media (max-width: 767px) {
    .page-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.8rem;
    }
    .cutoff-badge {
      text-align: left;
    }
    .territory-grid {
      grid-template-columns: repeat(7, minmax(0, 1fr));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
}
#mobile-nav-toggle:checked ~ aside .sidebar-label {
  max-width: 10rem;
  opacity: 1;
}
#mobile-nav-toggle:checked ~ aside nav a {
  width: 100%;
}
@layer components {
  .app-sidebar {
    background: #f8fbff;
    color: var(--color-portal-ink);
    border-color: var(--color-portal-line);
    box-shadow: 1px 0 0 rgba(4, 77, 152, 0.03);
  }
  .app-sidebar .sidebar-brand {
    border-color: var(--color-portal-line);
    background: #fff;
  }
  .app-sidebar .sidebar-brand svg, .app-sidebar .sidebar-brand .text-white {
    color: var(--color-brand-blue);
  }
  .app-sidebar .sidebar-brand .text-white\/55 {
    color: var(--color-portal-muted);
  }
  .app-sidebar nav a {
    width: 100%;
    min-height: 2.75rem;
    color: #536579;
  }
  .app-sidebar nav a:hover {
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .app-sidebar nav a[data-active] {
    box-shadow: none;
  }
  .app-sidebar .sidebar-foot {
    border-color: var(--color-portal-line);
    color: var(--color-portal-muted);
    background: #fff;
  }
  .app-sidebar .sidebar-foot > span:first-child {
    background: var(--color-brand-blue);
  }
  .app-topbar {
    border-top: 3px solid var(--color-brand-blue);
    background: #fff;
  }
  @media (min-width: 1024px) {
    .app-sidebar {
      width: 15rem !important;
    }
    .app-sidebar .sidebar-label {
      max-width: 11rem !important;
      opacity: 1 !important;
    }
    .app-sidebar nav a {
      width: 100% !important;
    }
  }
  .page-reportes .portal-container {
    max-width: 90rem;
  }
  .page-reportes .portal-container > div {
    border-color: #cfdbe6;
    border-radius: 0.45rem;
    box-shadow: 0 10px 28px rgba(23, 32, 51, 0.035);
  }
  .page-reportes .portal-container > div:nth-of-type(1) {
    border: 0;
    background: var(--color-brand-blue);
    color: #fff;
  }
  .page-reportes .portal-container > div:nth-of-type(1) > p:first-child, .page-reportes .portal-container > div:nth-of-type(1) .text-gray-900 {
    color: #fff;
  }
  .page-reportes .portal-container > div:nth-of-type(1) > p:nth-child(2) {
    color: rgba(255, 255, 255, 0.74);
  }
  .page-reportes .portal-container > div:nth-of-type(1) > .grid {
    background: rgba(255, 255, 255, 0.25);
    border-radius: 0.35rem;
  }
  .page-reportes .portal-container > div:nth-of-type(1) > .grid > div {
    background: rgba(255, 255, 255, 0.96);
  }
  .page-reportes .portal-container > div:nth-of-type(3) {
    background: var(--color-portal-blue-open);
    border-color: #b7cee4;
  }
  .page-reportes .portal-container > div:nth-of-type(4) .grid > div {
    border-top: 3px solid #adc8df;
    border-radius: 0.25rem;
    background: #f7fafc;
    padding: 1rem;
  }
  .page-reportes .portal-container > div:nth-of-type(4) .grid > div:nth-child(2) {
    border-top-color: var(--color-brand-blue);
    background: var(--color-portal-blue-open);
  }
  .page-reportes svg text {
    font-family: var(--font-sans);
  }
  .page-mapas .portal-container > .panel {
    border: 0;
    border-radius: 0.45rem;
    box-shadow: 0 10px 28px rgba(23, 32, 51, 0.04);
  }
  .page-mapas #map-canvas {
    border-radius: 0.35rem;
    border-color: #adc8df;
    background-color: #edf5fc !important;
    background-image: linear-gradient(rgba(4, 77, 152, 0.045) 1px, transparent 1px), linear-gradient(90deg, rgba(4, 77, 152, 0.045) 1px, transparent 1px) !important;
    background-size: 28px 28px !important;
  }
  .page-mapas .lg\:grid-cols-3 > div {
    border-radius: 0.45rem;
  }
  .page-mapas .tab-btn {
    min-height: 2.5rem;
    border-radius: 0.3rem;
    transition-property: color, background-color, scale;
  }
  .page-mapas .tab-btn[data-active] {
    background: var(--color-brand-blue);
    color: #fff;
  }
  .page-mapas #ranking-list button {
    min-height: 3rem;
    transition-property: color, background-color, scale;
  }
  .page-calendario .lg\:grid-cols-3 > div:first-child {
    border: 0;
    border-radius: 0.45rem;
    box-shadow: 0 12px 32px rgba(23, 32, 51, 0.06);
  }
  .page-calendario .day-cell {
    border-radius: 0.3rem;
    min-height: 3rem;
    transition: color 160ms var(--portal-ease), background-color 160ms var(--portal-ease), scale 120ms var(--portal-ease);
  }
  .page-calendario button.day-cell:hover {
    background: var(--color-portal-blue-open);
    color: var(--color-brand-blue);
  }
  .page-calendario .day-cell[data-today="true"] {
    background: var(--color-brand-blue);
    color: #fff;
  }
  .page-calendario .calendar-toolbar {
    gap: 0.75rem;
  }
  .page-calendario .portal-container, .page-calendario .portal-container > .grid, .page-calendario .lg\:col-span-2, .page-calendario #calendar-grid, .page-calendario #day-detail > div:last-child {
    min-width: 0;
  }
  .page-calendario .lg\:col-span-2 {
    max-width: 100%;
  }
  .page-calendario #day-detail {
    border: 0;
    border-radius: 0.4rem;
    background: var(--color-portal-blue-open);
    padding: 1rem;
  }
  .page-calendario .space-y-4 > div {
    border-radius: 0.4rem;
  }
  .page-calendario .space-y-4 > div:first-child {
    border: 0;
    background: var(--color-brand-blue);
  }
  .page-calendario .space-y-4 > div:first-child p {
    color: #fff;
  }
  .page-cedula .portal-container > .bg-white.flex {
    justify-content: space-between;
    border: 0;
    border-radius: 0.45rem;
    background: var(--color-brand-blue);
    color: #fff;
  }
  .page-cedula .portal-container > .grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    grid-template-rows: auto auto;
  }
  .page-cedula .portal-container > .grid > div {
    border-radius: 0.4rem;
  }
  .page-cedula .portal-container > .grid > div:first-child {
    grid-row: span 2;
    background: var(--color-portal-blue-open);
    border-color: #b7cee4;
  }
  .page-cedula .portal-container > .grid > div:nth-child(2) {
    background: #f8fafc;
  }
  .page-mision .portal-container > .panel {
    border: 0;
    border-radius: 0.45rem;
    background: var(--color-brand-blue);
  }
  .page-mision .portal-container > .panel p {
    color: #fff;
  }
  .page-mision .portal-container > .panel .status-chip {
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.14);
  }
  .page-mision .portal-container > .grid:nth-of-type(1) {
    grid-template-columns: 0.85fr 1.15fr;
  }
  .page-mision .portal-container > .grid:nth-of-type(1) > div:first-child {
    background: var(--color-portal-blue-open);
    border-color: #b7cee4;
  }
  .page-mision .portal-container > div:nth-last-child(1) {
    background: var(--color-portal-blue-open);
    border-color: #b7cee4;
  }
  @media (max-width: 767px) {
    .page-cedula .portal-container > .grid, .page-mision .portal-container > .grid:nth-of-type(1) {
      grid-template-columns: 1fr;
    }
    .page-cedula .portal-container > .grid > div:first-child {
      grid-row: auto;
    }
    .page-reportes .portal-container > div:nth-of-type(1) > .grid {
      grid-template-columns: 1fr;
    }
    .page-calendario .calendar-toolbar {
      align-items: flex-start;
      flex-direction: column;
    }
    .page-calendario .calendar-toolbar > div {
      flex-wrap: wrap;
      column-gap: 1rem;
      row-gap: 0.35rem;
      font-size: 0.75rem;
    }
  }
  @media (max-width: 479px) {
    .page-calendario .portal-page {
      padding-inline: 0.75rem;
    }
    .page-calendario .lg\:col-span-2 {
      padding: 0.75rem;
    }
    .page-calendario .day-cell {
      aspect-ratio: auto;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      min-height: 0;
      height: 2.75rem;
    }
  }
  .report-viz {
    overflow: hidden;
    border: 1px solid #d6e1eb;
    border-radius: 1rem;
    background: #fff;
    padding: clamp(1.15rem, 2vw, 1.6rem);
    box-shadow: 0 14px 38px rgba(6,44,86,0.055);
  }
  .report-viz__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .report-viz__head h2 {
    color: var(--color-portal-ink);
    font-size: 1.125rem;
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.015em;
  }
  .report-viz__head p {
    max-width: 50rem;
    margin-top: 0.3rem;
    color: var(--color-portal-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .report-viz__unit {
    flex: none;
    border: 1px solid #c9dae8;
    border-radius: 0.5rem;
    background: #f2f7fb;
    padding: 0.42rem 0.62rem;
    color: #526a80;
    font-family: var(--font-data);
    font-size: var(--text-meta);
    font-weight: 600;
  }
  .report-chart {
    display: block;
    width: 100%;
    overflow: visible;
  }
  .report-chart--range {
    height: clamp(16.5rem, 25vw, 19rem);
  }
  .report-chart--avance {
    height: 17rem;
  }
  .report-viz__note {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 0.4rem;
    color: #526a80;
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .report-viz__note > span {
    flex: none;
    width: 0.55rem;
    height: 0.55rem;
    margin-top: 0.42rem;
    border: 2px solid #fff;
    border-radius: 50%;
    background: var(--color-brand-blue);
    box-shadow: 0 0 0 3px #dcebf6;
  }
  .advance-analysis {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    align-items: stretch;
    gap: 1.4rem;
    margin-top: 1rem;
  }
  .advance-insight {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 1px solid #d9e4ed;
    padding: 0.4rem 0 0.4rem 1.4rem;
  }
  .advance-insight__eyebrow {
    color: var(--color-brand-blue);
    font-family: var(--font-data);
    font-size: var(--text-meta);
    font-weight: 600;
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }
  .advance-insight__metric {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    align-items: center;
    gap: 0.8rem;
    margin-top: 1rem;
  }
  .advance-insight__metric strong {
    color: var(--color-brand-blue);
    font-family: var(--font-data);
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.05em;
  }
  .advance-insight__metric span {
    color: #334e68;
    font-size: 0.9375rem;
    line-height: 1.4;
  }
  .advance-insight__metric--positive strong {
    color: #0a6ab7;
  }
  .advance-insight__foot {
    margin-top: 1.15rem;
    border-top: 1px solid #e2eaf1;
    padding-top: 0.9rem;
    color: #607085;
    font-size: var(--text-meta);
    line-height: 1.5;
  }
  @media (max-width: 1023px) {
    .advance-analysis {
      grid-template-columns: 1fr;
    }
    .advance-insight {
      display: grid;
      grid-template-columns: auto 1fr 1fr;
      align-items: center;
      border-top: 1px solid #d9e4ed;
      border-left: 0;
      padding: 1rem 0 0;
    }
    .advance-insight__metric {
      margin-top: 0;
    }
    .advance-insight__foot {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 767px) {
    .report-viz__head {
      flex-direction: column;
      gap: 0.75rem;
    }
    .report-viz__unit {
      align-self: flex-start;
    }
    #rango-wrap {
      margin-inline: -0.15rem;
      overflow-x: auto;
      padding-bottom: 0.35rem;
      scrollbar-width: thin;
    }
    .report-chart--range {
      min-width: 41rem;
      height: 17rem;
    }
    .report-chart--avance {
      height: auto;
    }
    .advance-insight {
      grid-template-columns: 1fr;
    }
    .advance-insight__eyebrow {
      margin-bottom: 0.2rem;
    }
    .advance-insight__metric {
      grid-template-columns: 3.2rem 1fr;
      margin-top: 0.85rem;
    }
    .advance-insight__metric strong {
      font-size: 2rem;
    }
  }
}
